{
  "name": "venoms-map-painter",
  "version": "v1.1.0",
  "description": "A desktop tool for painting CK3 mod province maps with automatic file generation",
  "author": "Ven0m",
  "license": "MIT",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/electron-dev.js dev",
    "build": "electron-vite build",
    "start": "node scripts/electron-dev.js preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config electron-builder.yml",
    "lint": "eslint src/ --ext .ts,.tsx"
  },
  "dependencies": {
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^24.9.0",
    "electron-vite": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  }
}
